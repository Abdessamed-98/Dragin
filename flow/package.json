{
  "name": "dragin-flow",
  "version": "1.0.0",
  "productName": "Dragin Flow",
  "description": "Drag-and-drop file processing dock",
  "author": "Dragin <noreply@dragin.dev>",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && node launch-electron.js\"",
    "build": "tsc && vite build",
    "build:dist": "node scripts/build.js",
    "preview": "vite preview",
    "start": "node launch-electron.js"
  },
  "devDependencies": {
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.2",
    "vite": "^6.1.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "electron-log": "^5.4.3",
    "framer-motion": "^12.0.6",
    "jszip": "^3.10.1",
    "lucide-react": "^0.564.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.1",
    "uiohook-napi": "^1.5.4"
  },
  "build": {
    "appId": "dev.dragin.flow",
    "productName": "Dragin Flow",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/uiohook-napi/**/*"
    ],
    "files": [
      "main.js",
      "preload.js",
      "dist/**/*",
      "icon.png",
      "drag-icon.png"
    ],
    "extraResources": [
      {
        "from": "pyinstaller_dist/app",
        "to": "app"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Dragin Flow"
    }
  }
}
